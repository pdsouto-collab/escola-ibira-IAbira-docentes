generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

enum Role {
  EDUCADOR
  DIRETOR
  ADMIN
}

enum SessionStatus {
  BRIEFING
  GERADO
  REVISADO
  AGUARDANDO_DIRETORIA
  APROVADO
}

enum DocumentType {
  PPP
  BNCC
  PIKLER
  ESPACO_FISICO
}

model User {
  id                   String               @id @default(uuid())
  nome                 String
  sobrenome            String?
  email                String               @unique
  passwordHash         String
  role                 Role                 @default(EDUCADOR)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  pedagogicalSessions  PedagogicalSession[]
  userPreference       UserPreference?
}

model KnowledgeBaseEmbedding {
  id        String       @id @default(uuid())
  content   String
  embedding Unsupported("vector(1536)")
  metadata  DocumentType
  createdAt DateTime     @default(now())
}

model PedagogicalSession {
  id                        String        @id @default(uuid())
  educadorId                String
  educador                  User          @relation(fields: [educadorId], references: [id])
  status                    SessionStatus @default(BRIEFING)
  tema                      String?
  faixaEtaria               String?
  cicloNatureza             String?
  requiresDirectorApproval  Boolean       @default(false)
  directorFeedback          String?
  createdAt                 DateTime      @default(now())
  updatedAt                 DateTime      @updatedAt

  classifications           PedagogicalClassification[]
  agentLogs                 AgentLog[]
  finalContent              FinalContent?
  feedbacks                 Feedback[]
}

model UserPreference {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  preferences  String   @db.Text
  updatedAt    DateTime @updatedAt
}

model Feedback {
  id           String             @id @default(uuid())
  sessionId    String
  session      PedagogicalSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId       String
  rating       Int                // 1 (up) ou -1 (down)
  comment      String?            @db.Text
  createdAt    DateTime           @default(now())
}

model PedagogicalClassification {
  id          String             @id @default(uuid())
  sessionId   String
  session     PedagogicalSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  year        String             // "Infantil", "1º Ano", etc.
  subcategory String             // "Matemática", "Português", etc.
  createdAt   DateTime           @default(now())

  @@unique([sessionId, year, subcategory])
}

model AgentLog {
  id                   String             @id @default(uuid())
  sessionId            String
  session              PedagogicalSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  agentName            String
  input                String
  output               String
  createdAt            DateTime           @default(now())
}

model FinalContent {
  id                   String             @id @default(uuid())
  sessionId            String             @unique
  session              PedagogicalSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  content              String
  version              Int                @default(1)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

model Subcategory {
  id        String   @id @default(uuid())
  name      String
  year      String   // "Infantil", "1º Ano", etc.
  createdAt DateTime @default(now())

  @@unique([name, year])
}

model AgentConfig {
  id           String   @id @default(uuid())
  agentName    String   @unique // "ESCUTADOR" ou "CRIADOR"
  instructions String   @db.Text
  updatedAt    DateTime @updatedAt
}

